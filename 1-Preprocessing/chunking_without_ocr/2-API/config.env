# API Configuration
API_TITLE="Doküman Chunking API"
API_VERSION="1.0.0"
DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=False

# File Upload Limits
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=txt,pdf,docx,csv,xlsx,xls

# Processing Limits
MAX_CHUNK_SIZE=2000
MIN_CHUNK_SIZE=100
DEFAULT_CHUNK_SIZE=500
MAX_BATCH_FILES=10

# Redis Configuration (for production)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# CORS Settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=True
METRICS_PATH=/metrics

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
